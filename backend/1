[pytest]
minversion = 7.0
testpaths = tests
python_files = test_*.py
python_classes = Test*
python_functions = test_*

addopts =
    -ra
    --strict-markers
    --maxfail=1
    --cov=.
    --cov-report=term-missing
    --cov-report=xml
    --cov-fail-under=70

filterwarnings =
    ignore::DeprecationWarning
